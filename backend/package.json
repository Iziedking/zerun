{
  "name": "zerun-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Zerun coordinator, solver runner, and read API. The agents reason on 0G Compute.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "compute:check": "tsx src/scripts/computeCheck.ts",
    "storage:check": "tsx src/scripts/storageCheck.ts",
    "analyst:check": "tsx src/scripts/analystCheck.ts",
    "ledger:fund": "tsx src/scripts/fundLedger.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "selftest": "tsx src/scripts/selfTest.ts",
    "poker:test": "tsx src/scripts/pokerTest.ts",
    "seed": "tsx src/scripts/seedAndRun.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "1.2.10",
    "@0glabs/0g-serving-broker": "0.6.2",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "hono": "^4.6.14",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "viem": "^2.21.55",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
