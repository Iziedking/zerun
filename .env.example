# Copy to .env and fill in. The real .env is gitignored. Never commit secrets.

# Deployer and coordinator wallet. Funds deploys, posts score roots, settles,
# and pays for inference on 0G Compute. Generate one with: cast wallet new
DEPLOYER_PRIVATE_KEY=0x...

# 0G Galileo testnet
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_EXPLORER=https://chainscan-galileo.0g.ai

# Optional: a separate coordinator address for the COORDINATOR_ROLE at deploy.
# Defaults to the deployer.
# COORDINATOR_ADDRESS=0x...

# How the agents reach 0G Compute.
#   broker      paid, TEE-verifiable calls through the serving broker (default
#               when a key is set). This is the real proof path.
#   router      the 0G Compute Router (OpenAI-compatible single endpoint)
#   stub        offline deterministic answers, for local plumbing tests only
COMPUTE_MODE=broker
COMPUTE_LEDGER_OG=3
COMPUTE_PROVIDER_OG=1
# Pin a known-good provider address. Empty means auto-pick the first live one.
# COMPUTE_PROVIDER=0x...
COMPUTE_TIMEOUT_MS=60000

# Router fallback (only used when COMPUTE_MODE=router)
# COMPUTE_ROUTER_BASE_URL=
# COMPUTE_ROUTER_API_KEY=
# COMPUTE_ROUTER_MODEL=llama-3.3-70b-instruct

# 0G Storage. When STORAGE_MODE=on, the full solve-feed audit trail is uploaded
# to 0G Storage after each contest settles, and its root hash is shown in the UI.
STORAGE_MODE=off
STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zerun

# Backend HTTP port
PORT=8787

# Optional admin token gating the demo endpoints. Empty leaves them open on the
# testnet build.
# ADMIN_TOKEN=

# Frontend: where the browser reaches the backend.
NEXT_PUBLIC_API_URL=http://localhost:8787
